<view class="page-wrap">

  <!-- ─── 页面标题区 ─── -->
  <view class="page-header">
    <view class="header-icon">✏️</view>
    <view class="header-title">创建自定义清单</view>
    <view class="header-sub">填写名称并逐条添加事项</view>
  </view>

  <view class="container">

    <!-- ─── 清单信息 ─── -->
    <view class="section-label">清单名称</view>
    <view class="input-card">
      <input
        class="title-input"
        value="{{title}}"
        placeholder="例如：周末采购清单"
        placeholder-class="input-placeholder"
        bindinput="onTitleInput"
      />
    </view>

    <!-- ─── 添加事项 ─── -->
    <view class="section-label">添加事项</view>
    <view class="add-card">
      <input
        class="item-input"
        value="{{newItemText}}"
        placeholder="输入一条事项，按确认添加"
        placeholder-class="input-placeholder"
        bindinput="onItemInput"
        confirm-type="done"
        bindconfirm="addItem"
      />
      <button class="add-btn" bindtap="addItem">添加</button>
    </view>

    <!-- ─── 事项列表 ─── -->
    <view class="section-label">事项列表
      <text class="label-count" wx:if="{{items.length > 0}}">（{{items.length}} 项）</text>
    </view>

    <view wx:if="{{items.length === 0}}" class="empty-card">
      <view class="empty-icon">📝</view>
      <view class="empty-text">还没有事项，先添加几条内容</view>
    </view>

    <view class="cell-group" wx:if="{{items.length > 0}}">
      <view wx:for="{{items}}" wx:key="id" class="item-cell">
        <view class="item-dot"></view>
        <view class="item-text">{{item.text}}</view>
        <view class="item-remove" data-index="{{index}}" bindtap="removeItem">删除</view>
      </view>
    </view>

    <!-- ─── 保存按钮 ─── -->
    <button class="save-btn primary-btn" bindtap="saveList">保存并打开清单</button>

    <view class="bottom-safe"></view>
  </view>

</view>
