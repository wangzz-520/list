.page-wrap {
  min-height: 100vh;
  background: #f6f8fb;
}

.page-header {
  padding: 34rpx 30rpx 30rpx;
  color: #172033;
  text-align: left;
  background: #f6f8fb;
}

.header-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 18rpx;
  font-size: 38rpx;
  background: #edf4ff;
  border-radius: 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
}

.header-sub {
  margin-top: 8rpx;
  color: #75839a;
  font-size: 26rpx;
}

.container {
  min-height: auto;
  padding: 0 24rpx 48rpx;
  background: #f6f8fb;
}

.section-label {
  display: flex;
  align-items: center;
  padding: 26rpx 2rpx 12rpx;
  color: #4d5f7a;
  font-size: 26rpx;
  font-weight: 800;
}

.label-count {
  color: #2f6fed;
  font-weight: 800;
}

.input-card,
.add-card,
.cell-group,
.empty-card {
  background: #ffffff;
  border: 1rpx solid #e5ebf5;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 22rpx rgba(42, 61, 102, 0.04);
}

.input-card {
  padding: 0 24rpx;
}

.title-input {
  width: 100%;
  height: 96rpx;
  color: #172033;
  font-size: 31rpx;
  font-weight: 700;
}

.add-card {
  display: flex;
  align-items: center;
  padding: 12rpx;
}

.item-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  color: #172033;
  font-size: 28rpx;
  background: transparent;
}

.input-placeholder {
  color: #a3afc2;
  font-weight: 400;
}

.add-btn {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 72rpx;
  padding: 0;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: normal;
  background: #2f6fed;
  border: none;
  border-radius: 12rpx;
}

.add-btn::after {
  border: none;
}

.empty-card {
  padding: 64rpx 24rpx;
  text-align: center;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto;
  font-size: 44rpx;
  background: #f3f6fb;
  border-radius: 50%;
}

.empty-text {
  margin-top: 18rpx;
  color: #8793a8;
  font-size: 27rpx;
}

.cell-group {
  overflow: hidden;
}

.item-cell {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  padding: 20rpx 22rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.item-cell:last-child {
  border-bottom: none;
}

.item-dot {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  margin-right: 18rpx;
  background: #edf4ff;
  border: 4rpx solid #2f6fed;
  border-radius: 50%;
}

.item-text {
  flex: 1;
  min-width: 0;
  color: #172033;
  font-size: 29rpx;
  line-height: 1.5;
  word-break: break-all;
}

.item-remove {
  flex-shrink: 0;
  margin-left: 18rpx;
  padding: 8rpx 12rpx;
  color: #d93f3f;
  font-size: 24rpx;
  background: #fff4f4;
  border-radius: 10rpx;
}

.save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 92rpx;
  padding: 0;
  margin-top: 34rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: normal;
  border-radius: 16rpx;
  box-shadow: 0 12rpx 24rpx rgba(47, 111, 237, 0.18);
}

.save-btn::after {
  border: none;
}

.bottom-safe {
  height: 36rpx;
}
