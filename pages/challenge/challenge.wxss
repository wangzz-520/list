.page-wrap {
  min-height: 100vh;
  background: #f6f8fb;
}

.hero {
  padding: 42rpx 32rpx 76rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2f6fed 0%, #5d91f4 100%);
}

.hero-kicker {
  font-size: 25rpx;
  font-weight: 700;
  opacity: 0.88;
}

.hero-title {
  margin-top: 14rpx;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.28;
}

.hero-sub {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
  line-height: 1.55;
}

.container {
  min-height: 72vh;
  padding: 0 24rpx 48rpx;
  margin-top: -38rpx;
  background: #f6f8fb;
  border-radius: 28rpx 28rpx 0 0;
}

.summary-card,
.check-card,
.week-card {
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 28rpx rgba(42, 61, 102, 0.06);
}

.summary-card {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-num {
  color: #2f6fed;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.15;
}

.summary-label {
  margin-top: 6rpx;
  color: #75839a;
  font-size: 24rpx;
}

.summary-line {
  width: 1rpx;
  height: 72rpx;
  background: #e8edf6;
}

.check-card {
  padding: 34rpx 28rpx;
  margin-top: 20rpx;
  text-align: center;
}

.check-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto;
  font-size: 48rpx;
  background: #edf4ff;
  border-radius: 50%;
}

.check-title {
  margin-top: 18rpx;
  color: #172033;
  font-size: 34rpx;
  font-weight: 800;
}

.check-desc {
  margin-top: 8rpx;
  color: #75839a;
  font-size: 25rpx;
}

.check-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  padding: 0;
  margin-top: 28rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: normal;
  background: #2f6fed;
  border: none;
  border-radius: 16rpx;
}

.check-btn.checked {
  color: #2f6fed;
  background: #edf4ff;
}

.check-btn::after {
  border: none;
}

.section-title {
  padding: 30rpx 4rpx 14rpx;
  color: #4d5f7a;
  font-size: 27rpx;
  font-weight: 800;
}

.week-card {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 14rpx;
}

.day-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.day-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  margin: 0 auto;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  background: #d7dfec;
  border-radius: 50%;
}

.day-item.done .day-dot {
  background: #2f6fed;
}

.day-week {
  margin-top: 10rpx;
  color: #4d5f7a;
  font-size: 22rpx;
  font-weight: 700;
}

.day-date {
  margin-top: 2rpx;
  color: #8793a8;
  font-size: 20rpx;
}

.reset-btn {
  width: 100%;
  margin-top: 30rpx;
}

.bottom-safe {
  height: 36rpx;
}
