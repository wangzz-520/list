<view class="page-wrap">
  <view class="tab-bar">
    <scroll-view scroll-x class="tab-scroll" scroll-with-animation>
      <view class="tab-inner">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="tab-item {{activeCategory === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectCategory"
        >
          <text class="tab-icon">{{item.icon}}</text>
          <text class="tab-text">{{item.name}}</text>
          <view class="tab-line" wx:if="{{activeCategory === item.id}}"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="search-wrap">
    <view class="search-bar">
      <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit"></image>
      <input
        class="search-input"
        value="{{keyword}}"
        placeholder="搜索：旅行 / 搬家 / 待产 / 面试"
        placeholder-class="search-placeholder"
        bindinput="onSearchInput"
        confirm-type="search"
      />
    </view>
  </view>

  <view wx:if="{{!keyword}}" class="cat-header">
    <view class="cat-header-icon">{{activeCategoryInfo.icon}}</view>
    <view class="cat-header-info">
      <view class="cat-header-name">{{activeCategoryInfo.name}}</view>
      <view class="cat-header-desc">{{activeCategoryInfo.desc}}</view>
    </view>
  </view>

  <view class="container">
    <view wx:if="{{keyword}}" class="search-title">搜索结果</view>

    <view wx:if="{{keyword && searchResults.length === 0}}" class="empty-wrap">
      <image class="empty-icon" src="/assets/icons/empty.svg" mode="aspectFit"></image>
      <view class="empty-text">没有找到相关清单</view>
    </view>

    <view class="cell-group" wx:if="{{keyword && searchResults.length > 0}}">
      <view
        wx:for="{{searchResults}}"
        wx:key="id"
        class="list-cell"
        data-id="{{item.id}}"
        bindtap="goChecklist"
        hover-class="cell-hover"
      >
        <view class="cell-icon">{{item.icon}}</view>
        <view class="cell-body">
          <view class="cell-title">{{item.title}}</view>
          <view class="cell-desc">{{item.description}}</view>
          <view class="tag">搜索结果</view>
        </view>
        <text class="cell-arrow">›</text>
      </view>
    </view>

    <view wx:if="{{!keyword && templates.length === 0}}" class="empty-wrap">
      <image class="empty-icon" src="/assets/icons/folder.svg" mode="aspectFit"></image>
      <view class="empty-text">该分类暂无清单</view>
    </view>

    <view class="cell-group" wx:if="{{!keyword && templates.length > 0}}">
      <view
        wx:for="{{templates}}"
        wx:key="id"
        class="list-cell"
        data-id="{{item.id}}"
        bindtap="goChecklist"
        hover-class="cell-hover"
      >
        <view class="cell-icon">{{item.icon}}</view>
        <view class="cell-body">
          <view class="cell-title">{{item.title}}</view>
          <view class="cell-desc">{{item.description}}</view>
          <view class="tag">{{activeCategoryInfo.name}}</view>
        </view>
        <text class="cell-arrow">›</text>
      </view>
    </view>

    <view class="bottom-safe"></view>
  </view>
</view>
