.page-wrap {
  min-height: 100vh;
  background: #f4f7fc;
}

.tab-bar {
  position: sticky;
  top: 0;
  z-index: 5;
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(42, 61, 102, 0.06);
}

.tab-scroll {
  white-space: nowrap;
}

.tab-inner {
  display: flex;
  padding: 0 18rpx;
}

.tab-item {
  position: relative;
  display: inline-flex;
  flex-shrink: 0;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 22rpx 0;
}

.tab-icon {
  margin-bottom: 6rpx;
  font-size: 30rpx;
}

.tab-text {
  padding-bottom: 18rpx;
  color: #697892;
  font-size: 25rpx;
}

.tab-item.active .tab-text {
  color: #2f6fed;
  font-weight: 800;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 42rpx;
  height: 6rpx;
  background: #2f6fed;
  border-radius: 999rpx;
  transform: translateX(-50%);
}

.search-wrap {
  padding: 20rpx 24rpx 0;
  background: #f4f7fc;
}

.search-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 26rpx;
  background: #ffffff;
  border: 1rpx solid #e3ebf7;
  border-radius: 22rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 53, 94, 0.06);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  color: #172033;
  font-size: 28rpx;
}

.search-placeholder {
  color: #a3afc2;
}

.cat-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e8edf6;
}

.cat-header-icon {
  flex-shrink: 0;
  width: 82rpx;
  margin-right: 20rpx;
  font-size: 52rpx;
  text-align: center;
}

.cat-header-info {
  flex: 1;
  min-width: 0;
}

.cat-header-name {
  color: #172033;
  font-size: 34rpx;
  font-weight: 800;
}

.cat-header-desc {
  margin-top: 6rpx;
  color: #75839a;
  font-size: 25rpx;
  line-height: 1.5;
}

.container {
  padding: 22rpx 24rpx 0;
  background: #f4f7fc;
}

.search-title {
  padding: 4rpx 4rpx 16rpx;
  color: #4d5f7a;
  font-size: 27rpx;
  font-weight: 800;
}

.cell-group {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e5ebf5;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 34rpx rgba(31, 53, 94, 0.06);
}

.list-cell {
  display: flex;
  align-items: center;
  min-height: 128rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.list-cell:last-child {
  border-bottom: none;
}

.cell-hover {
  background: #f2f6ff;
}

.cell-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  margin-right: 20rpx;
  font-size: 38rpx;
  background: #edf4ff;
  border-radius: 14rpx;
}

.cell-body {
  flex: 1;
  min-width: 0;
}

.cell-title {
  overflow: hidden;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-desc {
  margin-top: 6rpx;
  overflow: hidden;
  color: #75839a;
  font-size: 24rpx;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  color: #b2bfd3;
  font-size: 42rpx;
}

.empty-wrap {
  padding: 96rpx 24rpx;
  text-align: center;
}

.empty-icon {
  width: 92rpx;
  height: 92rpx;
  opacity: 0.78;
}

.empty-text {
  margin-top: 14rpx;
  color: #8793a8;
  font-size: 27rpx;
}

.bottom-safe {
  height: 56rpx;
}
