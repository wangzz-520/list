<view class="page-wrap">
  <view class="profile-header">
    <view class="profile-top">
      <image class="avatar" src="/assets/icons/logo.svg" mode="aspectFit"></image>
      <view class="profile-copy">
        <view class="profile-name">我的清单中心</view>
        <view class="profile-sub">{{syncStatusText}} · {{lastSyncText}}</view>
      </view>
    </view>
    <view class="stat-row">
      <view class="stat-item">
        <view class="stat-num">{{stats.customCount || 0}}</view>
        <view class="stat-label">我的清单</view>
      </view>
      <view class="stat-item">
        <view class="stat-num">{{stats.pinnedCount || 0}}</view>
        <view class="stat-label">常用</view>
      </view>
    </view>
  </view>

  <view class="main-content">
    <view class="sync-card">
      <view class="settings-left">
        <image class="settings-icon-img" src="/assets/icons/cloud.svg" mode="aspectFit"></image>
        <view class="settings-info">
          <view class="settings-name">数据同步状态</view>
          <view class="settings-sub">{{syncDesc}}</view>
        </view>
      </view>
    </view>

    <view class="section-row">
      <view class="group-title">最近生成的清单</view>
    </view>
    <view wx:if="{{customLists.length === 0}}" class="empty-card">
      <image class="empty-icon" src="/assets/icons/edit.svg" mode="aspectFit"></image>
      <view class="empty-text">从模板生成或选择助手保存的清单会出现在这里</view>
    </view>
    <view class="cell-group" wx:if="{{customLists.length > 0}}">
      <view wx:for="{{customLists}}" wx:key="id" class="list-cell">
        <view class="cell-main generated-main" data-id="{{item.id}}" bindtap="goChecklist">
          <view class="cell-icon">{{item.icon}}</view>
          <view class="cell-body">
            <view class="cell-title">{{item.title}}</view>
            <view class="cell-meta">{{item.itemCount}} 项 · {{item.generatedText}}</view>
          </view>
        </view>
        <button class="text-btn danger compact" data-id="{{item.id}}" catchtap="removeCustom">删除</button>
      </view>
    </view>

    <view class="group-title">常用清单</view>
    <view wx:if="{{pinnedTemplates.length === 0}}" class="empty-card compact">
      <view class="empty-text">打开模板清单后点“常用”，这里会集中管理</view>
    </view>
    <view class="cell-group" wx:if="{{pinnedTemplates.length > 0}}">
      <view wx:for="{{pinnedTemplates}}" wx:key="id" class="list-cell">
        <view class="cell-main" data-id="{{item.id}}" bindtap="goChecklist">
          <view class="cell-icon">{{item.icon}}</view>
          <view class="cell-body">
            <view class="cell-title">{{item.title}}</view>
            <view class="cell-desc">{{item.description}}</view>
          </view>
        </view>
        <button class="text-btn danger compact" data-id="{{item.id}}" catchtap="unpinTemplate">取消</button>
      </view>
    </view>

    <view class="group-title">工具与数据</view>
    <view class="settings-group">
      <view wx:if="{{isAdmin}}" class="settings-cell admin-cell" bindtap="goAdmin">
        <view class="settings-left">
          <image class="settings-icon-img" src="/assets/icons/cloud.svg" mode="aspectFit"></image>
          <view class="settings-info">
            <view class="settings-name">管理员中心</view>
            <view class="settings-sub">查看用户建议</view>
          </view>
        </view>
        <text class="settings-arrow">›</text>
      </view>
      <view wx:if="{{isAdmin}}" class="cell-divider"></view>
      <view class="settings-cell" bindtap="goWallpaper">
        <view class="settings-left">
          <image class="settings-icon-img" src="/assets/icons/folder.svg" mode="aspectFit"></image>
          <view class="settings-info">
            <view class="settings-name">壁纸下载</view>
            <view class="settings-sub">复制网盘链接后下载</view>
          </view>
        </view>
        <text class="settings-arrow">›</text>
      </view>
      <view class="cell-divider"></view>
      <view class="settings-cell" bindtap="goDecision">
        <view class="settings-left">
          <image class="settings-icon-img" src="/assets/icons/dice.svg" mode="aspectFit"></image>
          <view class="settings-info">
            <view class="settings-name">选择困难症助手</view>
            <view class="settings-sub">把选择结果保存为清单</view>
          </view>
        </view>
        <text class="settings-arrow">›</text>
      </view>
      <view class="cell-divider"></view>
      <view class="settings-cell share-row">
        <view class="settings-left">
          <image class="settings-icon-img" src="/assets/icons/share.svg" mode="aspectFit"></image>
          <view class="settings-info">
            <view class="settings-name">分享小程序</view>
            <view class="settings-sub">推荐给家人朋友一起用</view>
          </view>
        </view>
        <text class="settings-arrow">›</text>
        <button class="share-hit" open-type="share"></button>
      </view>
    </view>

    <view class="group-title">意见反馈</view>
    <view class="feedback-card">
      <textarea
        class="feedback-textarea"
        value="{{feedbackText}}"
        placeholder="例如：希望增加宠物出行清单、旅行目的地清单……"
        placeholder-class="input-placeholder"
        bindinput="onFeedbackInput"
        maxlength="200"
      />
      <button class="feedback-btn" bindtap="submitFeedback">提交反馈</button>
    </view>

    <view class="bottom-safe"></view>
  </view>
</view>
