.page-wrap {
  min-height: 100vh;
  background: #f4f7fc;
}

.profile-header {
  padding: 42rpx 30rpx 72rpx;
  color: #172033;
  background: linear-gradient(180deg, #ffffff 0%, #f5f8fd 100%);
}

.profile-top {
  display: flex;
  align-items: center;
}

.avatar {
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
  padding: 18rpx;
  margin-right: 22rpx;
  background: #edf4ff;
  border: 1rpx solid #dbe8ff;
  border-radius: 24rpx;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: #172033;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.25;
}

.profile-sub {
  margin-top: 8rpx;
  color: #75839a;
  font-size: 26rpx;
}

.stat-row {
  display: flex;
  gap: 14rpx;
  margin-top: 30rpx;
}

.stat-item {
  flex: 1;
  min-width: 0;
  padding: 20rpx 10rpx;
  text-align: center;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 24rpx rgba(42, 61, 102, 0.05);
}

.stat-num {
  color: #2f6fed;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.15;
}

.stat-label {
  margin-top: 6rpx;
  color: #75839a;
  font-size: 24rpx;
}

.main-content {
  min-height: 72vh;
  padding: 10rpx 24rpx 0;
  margin-top: -32rpx;
  background: #f4f7fc;
  border-radius: 28rpx 28rpx 0 0;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.group-title {
  padding: 28rpx 6rpx 14rpx;
  color: #4d5f7a;
  font-size: 29rpx;
  font-weight: 800;
}

.cell-group,
.settings-group,
.empty-card,
.sync-card {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 28rpx rgba(42, 61, 102, 0.05);
}

.sync-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 26rpx;
}

.list-cell {
  display: flex;
  align-items: flex-start;
  min-height: 122rpx;
  padding: 20rpx 22rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.list-cell:last-child {
  border-bottom: none;
}

.cell-main {
  display: flex;
  flex: 1;
  min-width: 0;
  align-items: center;
}

.generated-main {
  align-items: flex-start;
}

.cell-hover {
  background: #f2f6ff;
}

.cell-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 74rpx;
  height: 74rpx;
  margin-right: 18rpx;
  font-size: 36rpx;
  background: #edf4ff;
  border-radius: 14rpx;
}

.cell-icon.done {
  background: #ecfdf5;
}

.cell-body,
.settings-info {
  flex: 1;
  min-width: 0;
}

.cell-title {
  overflow: hidden;
  color: #172033;
  font-size: 31rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-desc {
  margin-top: 6rpx;
  overflow: hidden;
  color: #75839a;
  font-size: 25rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-meta {
  margin-top: 8rpx;
  overflow: hidden;
  color: #75839a;
  font-size: 25rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-btn,
.mini-btn {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  padding: 0;
  font-weight: 800;
  line-height: normal;
  border: none;
}

.text-btn {
  width: 82rpx;
  height: 56rpx;
  margin-left: 10rpx;
  margin-top: 10rpx;
  color: #2f6fed;
  font-size: 26rpx;
  background: #edf4ff;
  border-radius: 10rpx;
}

.text-btn.danger {
  color: #d93f3f;
  background: #fff4f4;
}

.text-btn.compact {
  width: 84rpx;
  min-width: 84rpx;
  font-size: 24rpx;
}

.mini-btn {
  width: 112rpx;
  height: 58rpx;
  color: #2f6fed;
  font-size: 26rpx;
  background: #edf4ff;
  border-radius: 999rpx;
}

.text-btn::after,
.mini-btn::after {
  border: none;
}

.empty-card {
  padding: 52rpx 24rpx;
  text-align: center;
}

.empty-card.compact {
  padding: 34rpx 24rpx;
}

.empty-icon {
  width: 84rpx;
  height: 84rpx;
  padding: 18rpx;
  background: #edf4ff;
  border-radius: 50%;
}

.empty-text {
  margin-top: 14rpx;
  color: #8793a8;
  font-size: 27rpx;
  line-height: 1.45;
}

.settings-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 106rpx;
  padding: 24rpx 26rpx;
}

.admin-cell {
  background: #f8fbff;
}

.share-row {
  position: relative;
}

.share-hit {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  opacity: 0;
}

.share-hit::after {
  border: none;
}

.settings-left {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
}

.settings-icon-img {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  padding: 8rpx;
  margin-right: 18rpx;
  background: #edf4ff;
  border-radius: 14rpx;
}

.settings-name {
  overflow: hidden;
  color: #172033;
  font-size: 31rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.settings-sub {
  margin-top: 4rpx;
  overflow: hidden;
  color: #75839a;
  font-size: 25rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.settings-arrow {
  color: #b2bfd3;
  font-size: 42rpx;
}

.cell-divider {
  height: 1rpx;
  margin-left: 26rpx;
  background: #edf1f7;
}

.danger-text {
  color: #d93f3f;
}

.input-placeholder {
  color: #a3afc2;
}

.bottom-safe {
  height: 56rpx;
}
