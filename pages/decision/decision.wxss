.page-wrap {
  min-height: 100vh;
  background: #f4f7fc;
}

.hero {
  padding: 42rpx 30rpx 72rpx;
  color: #172033;
  background: linear-gradient(180deg, #ffffff 0%, #f5f8fd 100%);
}

.hero-title {
  color: #172033;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.25;
}

.hero-sub {
  margin-top: 12rpx;
  color: #75839a;
  font-size: 26rpx;
  line-height: 1.55;
}

.container {
  min-height: 72vh;
  padding: 0 24rpx 48rpx;
  margin-top: -34rpx;
  background: #f4f7fc;
  border-radius: 28rpx 28rpx 0 0;
}

.section-title {
  padding: 28rpx 4rpx 14rpx;
  color: #4d5f7a;
  font-size: 29rpx;
  font-weight: 800;
}

.quick-row {
  display: flex;
  gap: 14rpx;
  overflow-x: auto;
  padding-bottom: 2rpx;
}

.quick-chip {
  flex-shrink: 0;
  padding: 16rpx 22rpx;
  color: #2f6fed;
  font-size: 27rpx;
  font-weight: 700;
  background: #ffffff;
  border: 1rpx solid #c9d8fb;
  border-radius: 999rpx;
}

.form-card,
.result-card,
.empty-card,
.history-list {
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 28rpx rgba(42, 61, 102, 0.05);
}

.form-card {
  padding: 26rpx;
  margin-top: 20rpx;
}

.label {
  color: #4d5f7a;
  font-size: 27rpx;
  font-weight: 800;
}

.options-label {
  margin-top: 24rpx;
}

.title-input,
.option-input {
  width: 100%;
  height: 82rpx;
  color: #172033;
  font-size: 30rpx;
  background: #f3f6fb;
  border-radius: 12rpx;
}

.title-input {
  margin-top: 12rpx;
  padding: 0 22rpx;
  font-weight: 700;
}

.option-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.option-input {
  flex: 1;
  min-width: 0;
  padding: 0 20rpx;
}

.remove-btn {
  flex-shrink: 0;
  padding: 12rpx 14rpx;
  color: #d93f3f;
  font-size: 26rpx;
  background: #fff4f4;
  border-radius: 10rpx;
}

.input-placeholder {
  color: #a3afc2;
}

.add-option-btn,
.choose-btn,
.reset-btn,
.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
  border-radius: 14rpx;
  font-weight: 800;
  line-height: normal;
}

.add-option-btn {
  width: 100%;
  height: 78rpx;
  margin-top: 18rpx;
  color: #2f6fed;
  font-size: 29rpx;
  background: #edf4ff;
}

.option-setting {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0 0;
  margin-top: 20rpx;
  border-top: 1rpx solid #edf1f7;
}

.setting-copy {
  flex: 1;
  min-width: 0;
}

.setting-title {
  color: #172033;
  font-size: 29rpx;
  font-weight: 800;
}

.setting-desc {
  margin-top: 6rpx;
  color: #75839a;
  font-size: 25rpx;
  line-height: 1.4;
}

.add-option-btn::after,
.choose-btn::after,
.reset-btn::after,
.clear-btn::after {
  border: none;
}

.result-card {
  padding: 30rpx;
  margin-top: 20rpx;
  text-align: center;
}

.result-label {
  color: #75839a;
  font-size: 27rpx;
}

.result-text {
  margin-top: 10rpx;
  color: #2f6fed;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.3;
  word-break: break-all;
}

.action-row {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.choose-btn {
  flex: 1;
  height: 88rpx;
  color: #ffffff;
  font-size: 31rpx;
  background: #2f6fed;
  box-shadow: 0 12rpx 24rpx rgba(47, 111, 237, 0.18);
}

.reset-btn {
  flex-shrink: 0;
  width: 132rpx;
  height: 88rpx;
  color: #4d5f7a;
  font-size: 29rpx;
  background: #ffffff;
  border: 1rpx solid #dfe7f2;
}

.history-title {
  padding-top: 34rpx;
}

.empty-card {
  padding: 58rpx 24rpx;
  text-align: center;
}

.empty-icon {
  width: 84rpx;
  height: 84rpx;
  padding: 18rpx;
  background: #edf4ff;
  border-radius: 50%;
}

.empty-text {
  margin-top: 14rpx;
  color: #8793a8;
  font-size: 28rpx;
}

.history-list {
  overflow: hidden;
}

.history-item {
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.history-title-text {
  overflow: hidden;
  color: #172033;
  font-size: 31rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-desc {
  margin-top: 6rpx;
  overflow: hidden;
  color: #75839a;
  font-size: 26rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.clear-btn {
  width: 100%;
  height: 78rpx;
  color: #d93f3f;
  font-size: 28rpx;
  background: #fff7f7;
}

.bottom-safe {
  height: 36rpx;
}
