.page-wrap {
  min-height: 100vh;
  background: #f4f7fc;
}

.hero {
  padding: 40rpx 32rpx 76rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #233f8f 0%, #2f6fed 58%, #6aa7ff 100%);
}

.hero-kicker {
  font-size: 24rpx;
  font-weight: 700;
  opacity: 0.86;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.25;
}

.hero-sub {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
  line-height: 1.55;
}

.container {
  min-height: 72vh;
  padding: 0 24rpx 48rpx;
  margin-top: -38rpx;
  background: #f4f7fc;
  border-radius: 28rpx 28rpx 0 0;
}

.checkin-card,
.cell-group,
.empty-card,
.quick-card {
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 28rpx rgba(42, 61, 102, 0.06);
}

.checkin-card {
  display: flex;
  align-items: center;
  min-height: 126rpx;
  padding: 24rpx;
}

.checkin-icon {
  width: 78rpx;
  height: 78rpx;
  padding: 16rpx;
  margin-right: 20rpx;
  background: #edf4ff;
  border-radius: 16rpx;
}

.checkin-body,
.cell-body {
  flex: 1;
  min-width: 0;
}

.checkin-title,
.cell-title {
  overflow: hidden;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.checkin-desc,
.cell-desc {
  margin-top: 6rpx;
  overflow: hidden;
  color: #75839a;
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  color: #b2bfd3;
  font-size: 42rpx;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 4rpx 14rpx;
}

.section-title {
  color: #4d5f7a;
  font-size: 27rpx;
  font-weight: 800;
}

.section-title.standalone {
  padding: 30rpx 4rpx 14rpx;
}

.section-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 54rpx;
  padding: 0;
  color: #2f6fed;
  font-size: 24rpx;
  font-weight: 800;
  line-height: normal;
  background: #edf4ff;
  border: none;
  border-radius: 999rpx;
}

.section-action::after {
  border: none;
}

.cell-group {
  overflow: hidden;
}

.list-cell,
.completed-cell {
  display: flex;
  align-items: center;
  min-height: 124rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.list-cell:last-child,
.completed-cell:last-child {
  border-bottom: none;
}

.cell-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 74rpx;
  height: 74rpx;
  margin-right: 18rpx;
  font-size: 36rpx;
  background: #edf4ff;
  border-radius: 14rpx;
}

.cell-icon.done {
  background: #ecfdf5;
}

.cell-tag {
  flex-shrink: 0;
  margin-left: 14rpx;
  color: #2f6fed;
  font-size: 23rpx;
  font-weight: 800;
}

.progress-track {
  height: 10rpx;
  margin-top: 12rpx;
  overflow: hidden;
  background: #e9eef7;
  border-radius: 999rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2f6fed, #68a1ff);
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.quick-card {
  min-width: 0;
  padding: 22rpx;
}

.quick-icon {
  font-size: 38rpx;
  line-height: 1;
}

.quick-title {
  margin-top: 12rpx;
  overflow: hidden;
  color: #172033;
  font-size: 27rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-tag {
  margin-top: 8rpx;
  color: #2f6fed;
  font-size: 22rpx;
  font-weight: 800;
}

.empty-card {
  padding: 50rpx 24rpx;
  text-align: center;
}

.empty-card.compact {
  padding: 34rpx 24rpx;
}

.empty-icon {
  width: 88rpx;
  height: 88rpx;
  opacity: 0.72;
}

.empty-text {
  margin-top: 12rpx;
  color: #8793a8;
  font-size: 25rpx;
}

.done-mark {
  flex-shrink: 0;
  color: #19a974;
  font-size: 34rpx;
  font-weight: 800;
}

.cell-hover {
  background: #f2f6ff;
}

.bottom-safe {
  height: 36rpx;
}
