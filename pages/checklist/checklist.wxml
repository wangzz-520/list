<view class="page-wrap">
  <view class="top-card">
    <view class="title-row">
      <view class="big-icon">{{icon}}</view>
      <view class="title-info">
        <view class="checklist-title">{{title}}</view>
        <view class="checklist-desc">{{description}}</view>
      </view>
    </view>

    <view class="progress-wrap">
      <view class="progress-meta">
        <text class="progress-label">{{progressLabel}}</text>
        <text class="progress-num">{{progress.done}} / {{progress.total}}</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progress.percent}}%;"></view>
      </view>
      <view class="progress-pct">{{progress.percent}}%</view>
    </view>

    <view class="action-row">
      <button class="action-btn-ghost" bindtap="toggleFavorite">
        <image class="action-icon" src="/assets/icons/heart.svg" mode="aspectFit"></image>
        <text>{{isFavorite ? '已收藏' : '收藏'}}</text>
      </button>
      <button class="action-btn-ghost" bindtap="togglePinned">
        <image class="action-icon" src="/assets/icons/calendar.svg" mode="aspectFit"></image>
        <text>{{isPinned ? '已常用' : '常用'}}</text>
      </button>
      <button class="action-btn-ghost" open-type="share">
        <image class="action-icon" src="/assets/icons/share.svg" mode="aspectFit"></image>
        <text>分享</text>
      </button>
    </view>
  </view>

  <view class="container">
    <view class="add-card">
      <view class="add-label">快速添加事项</view>
      <picker
        wx:if="{{groupOptions.length > 0}}"
        mode="selector"
        range="{{groupOptions}}"
        value="{{addGroupIndex}}"
        bindchange="onAddGroupChange"
      >
        <view class="group-picker">
          <text>添加到：{{groupOptions[addGroupIndex]}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
      <view class="add-row">
        <input
          class="add-input"
          value="{{newItemText}}"
          placeholder="例如：备用眼镜 / 车库遥控器"
          placeholder-class="input-placeholder"
          bindinput="onNewItemInput"
          confirm-type="done"
          bindconfirm="addItem"
        />
        <button class="add-submit" bindtap="addItem">加入</button>
      </view>
    </view>

    <view wx:for="{{groups}}" wx:key="id" wx:for-index="groupIndex" class="group-wrap">
      <view class="group-header">
        <text class="group-name">{{item.name}}</text>
        <text class="group-count">{{item.items.length}} 项</text>
      </view>

      <view wx:if="{{item.items.length === 0}}" class="group-empty">暂时没有事项</view>

      <view class="cell-group" wx:if="{{item.items.length > 0}}">
        <view
          wx:for="{{item.items}}"
          wx:for-item="task"
          wx:key="id"
          wx:for-index="itemIndex"
          class="task-cell {{task.checked ? checkedCellClass : ''}}"
          hover-class="task-hover"
        >
          <view
            class="checkbox {{task.checked ? 'checked' : ''}}"
            data-group-index="{{groupIndex}}"
            data-item-index="{{itemIndex}}"
            bindtap="toggleItem"
          >
            <text wx:if="{{task.checked}}" class="check-mark">✓</text>
          </view>
          <view
            class="task-text {{task.checked ? checkedTextClass : ''}}"
            data-group-index="{{groupIndex}}"
            data-item-index="{{itemIndex}}"
            bindtap="toggleItem"
          >{{task.text}}</view>
          <view
            class="task-delete"
            data-group-index="{{groupIndex}}"
            data-item-index="{{itemIndex}}"
            bindtap="deleteItem"
          >删除</view>
        </view>
      </view>
    </view>

    <view class="bottom-actions">
      <button class="reset-btn" bindtap="resetChecklist">
        <text>重置当前清单</text>
      </button>
      <button class="copy-btn" bindtap="copyChecklist">
        <text>{{primaryCopyText}}</text>
      </button>
    </view>

    <view class="bottom-safe"></view>
  </view>
</view>
