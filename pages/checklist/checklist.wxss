.page-wrap {
  min-height: 100vh;
  background: #f4f7fc;
}

.loading-card {
  margin: 28rpx 24rpx;
  padding: 72rpx 24rpx;
  text-align: center;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 18rpx;
}

.loading-title {
  color: #75839a;
  font-size: 29rpx;
  font-weight: 800;
}

.top-card {
  padding: 32rpx 30rpx 30rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e8edf6;
}

.title-row {
  display: flex;
  align-items: flex-start;
}

.big-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 94rpx;
  height: 94rpx;
  margin-right: 22rpx;
  font-size: 50rpx;
  background: #edf4ff;
  border-radius: 16rpx;
}

.title-info {
  flex: 1;
  min-width: 0;
}

.checklist-title {
  overflow: hidden;
  color: #172033;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.checklist-desc {
  margin-top: 8rpx;
  color: #75839a;
  font-size: 27rpx;
  line-height: 1.55;
}

.progress-wrap {
  margin-top: 30rpx;
}

.progress-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.progress-label {
  color: #4d5f7a;
  font-size: 27rpx;
  font-weight: 700;
}

.progress-num {
  color: #2f6fed;
  font-size: 27rpx;
  font-weight: 800;
}

.progress-track {
  height: 14rpx;
  overflow: hidden;
  background: #e9eef7;
  border-radius: 999rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2f6fed, #68a1ff);
  border-radius: 999rpx;
}

.progress-pct {
  margin-top: 8rpx;
  color: #8793a8;
  font-size: 24rpx;
  text-align: right;
}

.container {
  padding: 22rpx 24rpx 0;
  background: #f4f7fc;
}

.name-card {
  padding: 24rpx;
  margin-bottom: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e5ebf5;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 34rpx rgba(31, 53, 94, 0.06);
}

.name-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.name-label {
  min-width: 0;
  color: #4d5f7a;
  font-size: 28rpx;
  font-weight: 800;
}

.pin-action-row {
  display: flex;
  margin-top: 16rpx;
}

.pin-inline-btn {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  min-width: 188rpx;
  height: 58rpx;
  padding: 0 22rpx;
  margin: 0;
  color: #2f6fed;
  font-size: 27rpx;
  font-weight: 800;
  line-height: normal;
  background: #edf4ff;
  border: 1rpx solid #c9d8fb;
  border-radius: 999rpx;
}

.name-input {
  width: 100%;
  height: 76rpx;
  padding: 0 20rpx;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
  background: #f3f6fb;
  border: 1rpx solid #e6edf7;
  border-radius: 14rpx;
  box-sizing: border-box;
}

.add-card {
  padding: 24rpx;
  margin-bottom: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e5ebf5;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 34rpx rgba(31, 53, 94, 0.06);
}

.add-label {
  margin-bottom: 16rpx;
  color: #4d5f7a;
  font-size: 28rpx;
  font-weight: 800;
}

.group-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 64rpx;
  padding: 0 18rpx;
  margin-bottom: 14rpx;
  color: #2f6fed;
  font-size: 26rpx;
  font-weight: 800;
  background: #edf4ff;
  border-radius: 12rpx;
}

.picker-arrow {
  color: #7a99d6;
  font-size: 33rpx;
}

.add-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.add-input {
  flex: 1 1 auto;
  min-width: 0;
  width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  color: #172033;
  font-size: 29rpx;
  background: #f3f6fb;
  border: 1rpx solid #e6edf7;
  border-radius: 14rpx;
}

.input-placeholder {
  color: #a3afc2;
}

.add-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 88rpx;
  width: 88rpx;
  min-width: 88rpx;
  max-width: 88rpx;
  height: 76rpx;
  padding: 0;
  margin: 0;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: normal;
  background: #2f6fed;
  border: none;
  border-radius: 14rpx;
  box-shadow: 0 8rpx 18rpx rgba(47, 111, 237, 0.18);
}

.add-submit::after {
  border: none;
}

.group-wrap {
  margin-bottom: 22rpx;
}

.readonly-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.readonly-group {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e5ebf5;
  border-radius: 16rpx;
}

.readonly-group-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  color: #172033;
  font-size: 31rpx;
  font-weight: 800;
  background: #f8fbff;
  border-bottom: 1rpx solid #edf1f7;
}

.readonly-count {
  flex-shrink: 0;
  color: #2f6fed;
  font-size: 25rpx;
  font-weight: 800;
}

.readonly-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  padding: 20rpx;
}

.readonly-item {
  min-width: 0;
  padding: 18rpx 16rpx;
  background: #f8fbff;
  border: 1rpx solid #edf1f7;
  border-radius: 12rpx;
}

.readonly-text {
  overflow: hidden;
  color: #172033;
  font-size: 28rpx;
  line-height: 1.5;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.readonly-empty {
  padding: 38rpx 24rpx;
  color: #8793a8;
  font-size: 27rpx;
  text-align: center;
}

.group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 14rpx;
}

.group-name {
  color: #4d5f7a;
  font-size: 29rpx;
  font-weight: 800;
}

.group-count {
  color: #8793a8;
  font-size: 25rpx;
}

.group-empty {
  padding: 42rpx 24rpx;
  color: #8793a8;
  font-size: 28rpx;
  text-align: center;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
}

.cell-group {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e5ebf5;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 34rpx rgba(31, 53, 94, 0.06);
}

.task-cell {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.task-cell:last-child {
  border-bottom: none;
}

.task-hover {
  background: #f2f6ff;
}

.task-done {
  background: #fbfcff;
}

.task-selected {
  background: #f2f6ff;
}

.checkbox {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
  color: #ffffff;
  background: #ffffff;
  border: 3rpx solid #c7d1e2;
  border-radius: 50%;
  box-sizing: border-box;
  box-shadow: inset 0 0 0 6rpx #f7faff;
}

.checkbox.checked {
  background: linear-gradient(135deg, #2f6fed, #5d92ff);
  border-color: #2f6fed;
  box-shadow: 0 8rpx 18rpx rgba(47, 111, 237, 0.22);
}

.check-mark {
  width: 18rpx;
  height: 10rpx;
  margin-top: -4rpx;
  border-left: 5rpx solid #ffffff;
  border-bottom: 5rpx solid #ffffff;
  border-radius: 2rpx;
  transform: rotate(-45deg);
  box-sizing: border-box;
}

.task-text {
  flex: 1;
  min-width: 0;
  color: #172033;
  font-size: 31rpx;
  line-height: 1.5;
  word-break: break-all;
}

.readonly-task-text {
  padding-left: 0;
}

.text-done {
  color: #9aa6b8;
  text-decoration: line-through;
}

.task-delete {
  flex-shrink: 0;
  padding-left: 18rpx;
  color: #d93f3f;
  font-size: 26rpx;
}

.bottom-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  width: 100%;
  margin-top: 34rpx;
}

.copy-btn,
.reset-btn,
.share-bottom-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 250rpx;
  height: 76rpx;
  padding: 0 12rpx;
  margin: 0;
  border: none;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: normal;
  white-space: nowrap;
  box-sizing: border-box;
}

.copy-btn {
  color: #ffffff;
  background: #2f6fed;
  box-shadow: 0 12rpx 24rpx rgba(47, 111, 237, 0.18);
}

.reset-btn {
  color: #d93f3f;
  background: #fff4f4;
  border: 1rpx solid #ffe0e0;
}

.share-bottom-btn {
  flex: 1 1 100%;
  width: 100%;
  min-width: 0;
  color: #2f6fed;
  background: #edf4ff;
  border: 1rpx solid #c9d8fb;
}

.copy-btn::after,
.reset-btn::after,
.share-bottom-btn::after {
  border: none;
}


.bottom-safe {
  height: 56rpx;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 600px;
  height: 1400px;
  opacity: 0;
  pointer-events: none;
}
