.page-wrap {
  min-height: 100vh;
  background: #f6f8fb;
}

.banner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 38rpx 32rpx 70rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2f6fed 0%, #5d91f4 100%);
}

.banner-left {
  flex: 1;
  min-width: 0;
}

.banner-title {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.25;
}

.banner-sub {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 25rpx;
  line-height: 1.55;
}

.banner-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 220rpx;
  height: 70rpx;
  margin-top: 26rpx;
  color: #2f6fed;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 70rpx;
  background: #ffffff;
  border: none;
  border-radius: 12rpx;
}

.banner-btn::after {
  border: none;
}

.banner-emoji {
  flex-shrink: 0;
  margin: 8rpx 0 0 20rpx;
  font-size: 86rpx;
}

.main-content {
  min-height: 72vh;
  padding: 24rpx 24rpx 0;
  margin-top: -32rpx;
  background: #f6f8fb;
  border-radius: 28rpx 28rpx 0 0;
}

.search-bar {
  display: flex;
  align-items: center;
  height: 84rpx;
  padding: 0 24rpx;
  margin-bottom: 4rpx;
  background: #ffffff;
  border: 1rpx solid #e1e8f4;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(42, 61, 102, 0.06);
}

.search-icon {
  margin-right: 12rpx;
  font-size: 30rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  color: #172033;
  font-size: 28rpx;
}

.search-placeholder {
  color: #a3afc2;
}

.challenge-card,
.tool-card {
  display: flex;
  align-items: center;
  min-height: 128rpx;
  padding: 24rpx;
  margin: 24rpx 0 4rpx;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(42, 61, 102, 0.06);
}

.tool-card {
  margin-top: 16rpx;
}

.challenge-icon,
.tool-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  margin-right: 20rpx;
  font-size: 38rpx;
  background: #edf4ff;
  border-radius: 16rpx;
}

.challenge-body,
.tool-body {
  flex: 1;
  min-width: 0;
}

.challenge-title,
.tool-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
}

.challenge-desc,
.tool-desc {
  margin-top: 6rpx;
  color: #75839a;
  font-size: 24rpx;
}

.cat-grid {
  display: flex;
  flex-wrap: wrap;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
}

.cat-item {
  width: 25%;
  min-width: 0;
  padding: 28rpx 8rpx 24rpx;
  text-align: center;
}

.cat-hover,
.cell-hover,
.recent-hover {
  background: #f2f6ff;
}

.cat-icon {
  font-size: 42rpx;
  line-height: 1;
}

.cat-name {
  margin-top: 12rpx;
  overflow: hidden;
  color: #172033;
  font-size: 23rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-group {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
}

.list-cell {
  display: flex;
  align-items: center;
  min-height: 128rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.list-cell:last-child {
  border-bottom: none;
}

.cell-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  margin-right: 20rpx;
  font-size: 38rpx;
  background: #edf4ff;
  border-radius: 14rpx;
}

.cell-body {
  flex: 1;
  min-width: 0;
}

.cell-title {
  overflow: hidden;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-desc {
  margin-top: 6rpx;
  overflow: hidden;
  color: #75839a;
  font-size: 24rpx;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  color: #b2bfd3;
  font-size: 42rpx;
}

.recent-row {
  display: flex;
  gap: 16rpx;
  padding-bottom: 10rpx;
  overflow-x: auto;
}

.recent-card {
  flex: 0 0 168rpx;
  padding: 22rpx 14rpx;
  text-align: center;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
}

.recent-icon {
  font-size: 38rpx;
}

.recent-name {
  display: block;
  margin-top: 10rpx;
  overflow: hidden;
  color: #4d5f7a;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-wrap {
  padding: 72rpx 24rpx;
  text-align: center;
}

.empty-icon {
  font-size: 68rpx;
}

.empty-text {
  margin-top: 14rpx;
  color: #8793a8;
  font-size: 27rpx;
}

.bottom-safe {
  height: 56rpx;
}
