.page-wrap {
  min-height: 100vh;
  background: #f5f8fd;
}

.banner {
  padding: 34rpx 28rpx 38rpx;
  color: #172033;
  background: linear-gradient(180deg, #ffffff 0%, #f5f8fd 100%);
}

.brand-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.banner-logo {
  flex-shrink: 0;
  width: 58rpx;
  height: 58rpx;
  padding: 10rpx;
  margin-right: 16rpx;
  background: #edf4ff;
  border: 1rpx solid #dbe8ff;
  border-radius: 16rpx;
}

.brand-text {
  min-width: 0;
}

.brand-name {
  color: #172033;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
}

.brand-desc {
  margin-top: 4rpx;
  color: #75839a;
  font-size: 22rpx;
}

.banner-title {
  color: #111827;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.28;
}

.banner-sub {
  margin-top: 14rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.62;
}

.main-content {
  min-height: 72vh;
  padding: 0 24rpx 0;
  margin-top: -8rpx;
  background: #f5f8fd;
}

.action-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
}

.action-card {
  position: relative;
  display: flex;
  align-items: center;
  min-width: 0;
  min-height: 112rpx;
  padding: 22rpx 22rpx;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 18rpx;
  box-shadow: 0 10rpx 24rpx rgba(42, 61, 102, 0.05);
}

.action-card.primary {
  background: linear-gradient(135deg, #edf4ff 0%, #ffffff 72%);
  border-color: #c9d8fb;
}

.action-icon-wrap {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin-right: 18rpx;
  background: #f3f6fb;
  border-radius: 14rpx;
}

.action-icon-wrap.soft {
  background: #f0fdf8;
}

.action-card.primary .action-icon-wrap {
  background: #ffffff;
}

.action-icon {
  width: 42rpx;
  height: 42rpx;
}

.action-copy {
  flex: 1;
  min-width: 0;
}

.action-title {
  overflow: hidden;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-desc {
  margin-top: 6rpx;
  overflow: hidden;
  color: #75839a;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  color: #b2bfd3;
  font-size: 42rpx;
}

.section-title {
  padding: 30rpx 4rpx 14rpx;
  color: #4d5f7a;
  font-size: 27rpx;
  font-weight: 800;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pinned-row {
  display: flex;
  gap: 14rpx;
  overflow-x: auto;
  padding-bottom: 2rpx;
}

.pinned-card {
  flex: 0 0 188rpx;
  min-width: 0;
  padding: 20rpx 14rpx 18rpx;
  text-align: center;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
}

.pinned-icon {
  font-size: 38rpx;
  line-height: 1;
}

.pinned-title {
  margin-top: 10rpx;
  overflow: hidden;
  color: #172033;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.35;
  word-break: break-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.template-section-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.template-section,
.cell-group {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 24rpx rgba(42, 61, 102, 0.05);
}

.template-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  background: #f8fbff;
  border-bottom: 1rpx solid #e8edf6;
}

.template-section-main {
  display: flex;
  flex: 1;
  min-width: 0;
  align-items: center;
}

.template-section-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  margin-right: 18rpx;
  font-size: 34rpx;
  background: #ffffff;
  border: 1rpx solid #dbe8ff;
  border-radius: 14rpx;
}

.template-section-copy,
.template-mini-body,
.cell-body {
  flex: 1;
  min-width: 0;
}

.template-section-title,
.template-mini-title,
.cell-title {
  overflow: hidden;
  color: #172033;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-section-title {
  font-size: 30rpx;
}

.template-mini-title,
.cell-title {
  font-size: 28rpx;
}

.template-section-desc,
.template-mini-desc,
.cell-desc {
  margin-top: 6rpx;
  overflow: hidden;
  color: #75839a;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-mini,
.list-cell {
  display: flex;
  align-items: center;
  min-height: 118rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.template-mini:last-child,
.list-cell:last-child {
  border-bottom: none;
}

.template-mini-icon,
.cell-icon {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin-right: 18rpx;
  font-size: 32rpx;
  background: #f3f6fb;
  border-radius: 12rpx;
}

.template-mini-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.template-mini-heat {
  flex-shrink: 0;
  padding: 5rpx 10rpx;
  color: #19a974;
  font-size: 20rpx;
  font-weight: 800;
  background: #ecfdf5;
  border-radius: 999rpx;
}

.cell-arrow {
  flex-shrink: 0;
  margin-left: 12rpx;
  color: #b2bfd3;
  font-size: 40rpx;
}

.cell-hover {
  background: #f2f6ff;
}

.empty-wrap {
  padding: 72rpx 24rpx;
  text-align: center;
}

.empty-img {
  width: 92rpx;
  height: 92rpx;
  opacity: 0.72;
}

.empty-text {
  margin-top: 14rpx;
  color: #8793a8;
  font-size: 27rpx;
}

.bottom-safe {
  height: 56rpx;
}
