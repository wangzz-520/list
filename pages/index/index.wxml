<view class="page-wrap">
  <view class="banner">
    <view class="brand-row">
      <image class="banner-logo" src="/assets/icons/logo.svg" mode="aspectFit"></image>
      <view class="brand-text">
        <view class="brand-name">万能生活清单</view>
        <view class="brand-desc">本地优先 · 云端同步</view>
      </view>
    </view>
    <view class="banner-title">生活清单，一项项不漏</view>
    <view class="banner-sub">查看清单、场景模板、选择助手，都从这里开始。</view>
  </view>

  <view class="main-content">
    <view>
      <view class="action-grid">
        <view class="action-card primary" bindtap="goMine" hover-class="cell-hover">
          <view class="action-icon-wrap">
            <image class="action-icon" src="/assets/icons/folder.svg" mode="aspectFit"></image>
          </view>
          <view class="action-copy">
            <view class="action-title">查看清单</view>
            <view class="action-desc">最近生成与常用清单</view>
          </view>
          <text class="action-arrow">›</text>
        </view>
        <view class="action-card" bindtap="goDecision" hover-class="cell-hover">
          <view class="action-icon-wrap soft">
            <image class="action-icon" src="/assets/icons/dice.svg" mode="aspectFit"></image>
          </view>
          <view class="action-copy">
            <view class="action-title">选择困难症助手</view>
            <view class="action-desc">帮你快速做决定</view>
          </view>
          <text class="action-arrow">›</text>
        </view>
      </view>

      <view wx:if="{{pinnedTemplates.length > 0}}">
        <view class="section-title">常用清单</view>
        <view class="pinned-row">
          <view
            wx:for="{{pinnedTemplates}}"
            wx:key="id"
            class="pinned-card"
            data-id="{{item.id}}"
            bindtap="goChecklist"
            hover-class="cell-hover"
          >
            <view class="pinned-icon">{{item.icon}}</view>
            <view class="pinned-title">{{item.title}}</view>
          </view>
        </view>
      </view>

      <view class="section-row">
        <view class="section-title">精选模板</view>
      </view>

      <view class="template-section-list">
        <view wx:for="{{templateSections}}" wx:key="id" class="template-section">
          <view class="template-section-head">
            <view class="template-section-main">
              <view class="template-section-icon">{{item.icon}}</view>
              <view class="template-section-copy">
                <view class="template-section-title">{{item.name}}</view>
                <view class="template-section-desc">{{item.desc}}</view>
              </view>
            </view>
          </view>

          <view
            wx:for="{{item.templates}}"
            wx:for-item="tpl"
            wx:key="id"
            class="template-mini"
            data-id="{{tpl.id}}"
            bindtap="goChecklist"
            hover-class="cell-hover"
          >
            <view class="template-mini-icon">{{tpl.icon}}</view>
            <view class="template-mini-body">
              <view class="template-mini-top">
                <view class="template-mini-title">{{tpl.title}}</view>
                <view class="template-mini-heat">热度 {{tpl.heat}}</view>
              </view>
              <view class="template-mini-desc">{{tpl.description}}</view>
            </view>
            <text class="cell-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-safe"></view>
  </view>
</view>
