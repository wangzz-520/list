.page-wrap {
  min-height: 100vh;
  background: #f4f7fc;
}

.hero {
  padding: 42rpx 30rpx 72rpx;
  color: #172033;
  background: linear-gradient(180deg, #ffffff 0%, #f5f8fd 100%);
}

.hero-title {
  color: #172033;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
}

.hero-sub {
  margin-top: 12rpx;
  color: #75839a;
  font-size: 26rpx;
  line-height: 1.55;
}

.container {
  min-height: 72vh;
  padding: 0 24rpx 48rpx;
  margin-top: -34rpx;
  background: #f4f7fc;
  border-radius: 28rpx 28rpx 0 0;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  padding: 28rpx 4rpx 14rpx;
  color: #4d5f7a;
  font-size: 29rpx;
  font-weight: 800;
}

.refresh-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 64rpx;
  padding: 0;
  margin: 0;
  color: #2f6fed;
  font-size: 27rpx;
  font-weight: 800;
  line-height: normal;
  background: #edf4ff;
  border: 1rpx solid #c9d8fb;
  border-radius: 14rpx;
}

.refresh-btn::after {
  border: none;
}

.feedback-list,
.empty-card {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  border-radius: 18rpx;
  box-shadow: 0 12rpx 30rpx rgba(42, 61, 102, 0.06);
}

.feedback-item {
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.feedback-item:last-child {
  border-bottom: none;
}

.feedback-content {
  color: #172033;
  font-size: 29rpx;
  line-height: 1.55;
  word-break: break-all;
}

.feedback-meta {
  margin-top: 10rpx;
  color: #8793a8;
  font-size: 24rpx;
}

.empty-card {
  padding: 64rpx 28rpx;
  text-align: center;
}

.empty-card.compact {
  padding: 36rpx 24rpx;
}

.empty-icon {
  width: 92rpx;
  height: 92rpx;
  opacity: 0.72;
}

.empty-text {
  margin-top: 14rpx;
  color: #4d5f7a;
  font-size: 29rpx;
  font-weight: 800;
}

.empty-sub {
  margin-top: 8rpx;
  color: #8793a8;
  font-size: 25rpx;
}

.bottom-safe {
  height: 40rpx;
}
